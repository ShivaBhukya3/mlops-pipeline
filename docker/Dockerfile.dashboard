FROM python:3.11-slim

WORKDIR /app

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app

RUN pip install --no-cache-dir \
    fastapi "uvicorn[standard]" jinja2 aiofiles httpx pydantic \
    numpy scipy pyyaml

COPY dashboard/ ./dashboard/
COPY src/ ./src/
COPY config/ ./config/

EXPOSE 8050

# Use $PORT env var (Render injects this automatically)
CMD uvicorn dashboard.main:app --host 0.0.0.0 --port ${PORT:-8050}
