# ── MLflow ───────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=fraud-detection

# ── FastAPI ───────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CONFIG_PATH=config/config.yaml

# ── Dashboard ─────────────────────────────────────
ML_API_URL=http://localhost:8000
DASHBOARD_PORT=8050

# ── Database ──────────────────────────────────────
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops_secret
POSTGRES_DB=mlops
DATABASE_URL=postgresql://mlops:mlops_secret@localhost:5432/mlops

# ── AWS (for production) ──────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
S3_BUCKET=mlops-fraud-detection

# ── Alerts ────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/...
ALERT_EMAIL=mlops@company.com
